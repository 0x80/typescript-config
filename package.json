    "service",
    "node",
    "cloudflare",
    "workers",
    "pulumi",
    "alchemy",
    "bundler"
  ],
  "files": [
    "src"
  ],
  "exports": {
    "./base": "./src/base.json",
    "./library": "./src/library.json",
    "./library-isomorphic": "./src/library-isomorphic.json",
    "./library-react": "./src/library-react.json",
    "./nextjs": "./src/nextjs.json",
    "./service-node": "./src/service-node.json",
    "./service-worker": "./src/service-worker.json",
    "./shared-library": "./src/shared-library.json",
    "./shared-library-react": "./src/shared-library-react.json",
    "./infra-pulumi": "./src/infra-pulumi.json",
    "./infra-alchemy": "./src/infra-alchemy.json"
  },
  "peerDependencies": {
    "typescript": ">=6.0.0"
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "typescript": "^6.0.1-rc",
    "vitepress": "^1.6.3"
  },
  "packageManager": "pnpm@9.8.0"
