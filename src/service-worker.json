{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Backend service (Cloudflare Workers)",
  "extends": "./base.json",
  "compilerOptions": {
    /** Assuming your bundler will output everything. */
    "noEmit": true,
    /**
     * TypeScript 6 no longer auto-includes @types packages. Worker services
     * run on the Cloudflare Workers runtime, so we explicitly include
     * @cloudflare/workers-types instead of @types/node.
     */
    "types": ["@cloudflare/workers-types"]
  }
}
